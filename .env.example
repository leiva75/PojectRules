# ===========================================
# Pointeuse Hybride - Variables de Entorno
# ===========================================
# Copiar este archivo a .env y configurar los valores

# -----------------------------------------
# Base de Datos PostgreSQL
# -----------------------------------------
# URL de conexión (formato: postgres://user:password@host:port/database)
DATABASE_URL=postgres://postgres:${DB_PASSWORD}@db:5432/pointeuse

# Contraseña de PostgreSQL (OBLIGATORIO en producción)
DB_PASSWORD=cambiar_esta_password

# -----------------------------------------
# Autenticación y Seguridad
# -----------------------------------------
# Clave secreta para JWT - mínimo 32 caracteres (OBLIGATORIO)
# Generar con: openssl rand -base64 32
SESSION_SECRET=

# Origen permitido para CORS (OBLIGATORIO en producción)
# Ejemplo: https://mi-dominio.com
CORS_ORIGIN=

# -----------------------------------------
# Entorno
# -----------------------------------------
# development | production
NODE_ENV=production

# Puerto del servidor (por defecto 5000)
PORT=5000

# -----------------------------------------
# Configuración de Horas Extras
# -----------------------------------------
# Minutos de trabajo esperados por día (8 horas = 480)
EXPECTED_DAILY_MINUTES=480

# Umbral mínimo de overtime para crear solicitud (minutos)
OVERTIME_MIN_THRESHOLD=15

# -----------------------------------------
# Backups (opcional)
# -----------------------------------------
# Directorio para guardar backups
BACKUP_DIR=/backups

# Días de retención de backups
RETENTION_DAYS=30
