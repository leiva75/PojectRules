# ===========================================
# Pointeuse Hybride - Variables de Entorno
# ===========================================
# Copiar este archivo a .env y configurar los valores

# -----------------------------------------
# Base de Datos PostgreSQL
# -----------------------------------------
# URL de conexión (formato: postgres://user:password@host:port/database)
DATABASE_URL=postgres://user:password@localhost:5432/pointeuse

# -----------------------------------------
# Autenticación JWT (OBLIGATORIO en producción)
# -----------------------------------------
# Generar con: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# -----------------------------------------
# Modo Quiosco (OBLIGATORIO en producción)
# -----------------------------------------
# Clave para acceso quiosco - mínimo 16 caracteres
# Generar con: openssl rand -base64 24
KIOSK_KEY=

# -----------------------------------------
# CORS (OBLIGATORIO en producción)
# -----------------------------------------
# Origen permitido - NO usar * en producción
# Ejemplo: https://pointeuse.midominio.com
CORS_ORIGIN=

# -----------------------------------------
# Entorno
# -----------------------------------------
# development | production
NODE_ENV=production

# Puerto del servidor (PaaS lo asigna automáticamente)
PORT=5000

# -----------------------------------------
# Configuración de Horas Extras (opcional)
# -----------------------------------------
# Minutos de trabajo esperados por día (8 horas = 480)
EXPECTED_DAILY_MINUTES=480

# Umbral mínimo de overtime para crear solicitud (minutos)
OVERTIME_MIN_THRESHOLD=15
