# ============================================
# Pointeuse Hybride - Variables de Produccion
# ============================================
# Copiar a .env y configurar los valores reales
# NO commitear el archivo .env con secrets reales

# -----------------------------------------
# Base de Datos PostgreSQL
# -----------------------------------------
POSTGRES_DB=pointeuse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# URL de conexion (el contenedor app la construye automaticamente)
# Solo necesaria si se conecta desde fuera de Docker
# DATABASE_URL=postgres://postgres:PASSWORD@localhost:5432/pointeuse

# -----------------------------------------
# Seguridad y Autenticacion
# -----------------------------------------
# Clave secreta para access tokens JWT (minimo 32 caracteres)
# Generar con: openssl rand -base64 32
JWT_ACCESS_SECRET=

# Clave secreta para refresh tokens JWT (minimo 32 caracteres)
# Generar con: openssl rand -base64 32
JWT_REFRESH_SECRET=

# Clave de acceso al modo kiosko (minimo 16 caracteres)
# Generar con: openssl rand -base64 16
KIOSK_KEY=

# -----------------------------------------
# CORS y Dominio
# -----------------------------------------
# Origen permitido para peticiones CORS
# Ejemplo: https://fichaje.miempresa.com
CORS_ORIGIN=https://TU_DOMINIO_AQUI

# -----------------------------------------
# Configuracion de la Aplicacion
# -----------------------------------------
# Puerto del servidor (por defecto 3000)
PORT=3000

# Minutos de trabajo esperados por dia (8 horas = 480)
EXPECTED_DAILY_MINUTES=480

# Umbral minimo de horas extra para crear solicitud (minutos)
OVERTIME_MIN_THRESHOLD=15

# Decimales para redondeo de coordenadas GPS
GEO_DECIMALS=4
