# =============================================================
# Nginx — Cronos Fichajes + Gimnasio Cronos (mismo Droplet)
# =============================================================
# Gimnasio Cronos   → gestion.cronosfichajes.es → :3000
# Cronos Fichajes   → cronosfichajes.es         → :3001
# =============================================================

# --- Gimnasio Cronos (gestion.cronosfichajes.es) ---

server {
    listen 80;
    server_name gestion.cronosfichajes.es;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name gestion.cronosfichajes.es;

    ssl_certificate     /etc/letsencrypt/live/gestion.cronosfichajes.es/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gestion.cronosfichajes.es/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}

# --- Cronos Fichajes (cronosfichajes.es) ---

server {
    listen 80;
    server_name cronosfichajes.es www.cronosfichajes.es;
    return 301 https://cronosfichajes.es$request_uri;
}

server {
    listen 443 ssl http2;
    server_name cronosfichajes.es www.cronosfichajes.es;

    ssl_certificate     /etc/letsencrypt/live/cronosfichajes.es/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cronosfichajes.es/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
